        {
          "name": "Events",
          "item": [
            {
              "name": "Upload Event Poster",
              "request": {
                "method": "POST",
                "url": { "raw": "{{baseUrl}}/admin/events/upload-poster", "host": ["{{baseUrl}}"], "path": ["admin", "events", "upload-poster"] },
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "body": {
                  "mode": "formdata",
                  "formdata": [{ "key": "file", "type": "file", "src": "/path/to/poster.jpg" }]
                },
                "description": "Upload an event poster image. Returns { imageUrl }. Stored in /uploads/events/."
              },
              "response": []
            },
            {
              "name": "Create Event",
              "request": {
                "method": "POST",
                "url": { "raw": "{{baseUrl}}/admin/events", "host": ["{{baseUrl}}"], "path": ["admin", "events"] },
                "header": [
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" },
                  { "key": "Content-Type",  "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"The Dark Knight\",\n  \"slug\": \"the-dark-knight\",\n  \"releaseType\": \"THEATRICAL\",\n  \"trailerVideoLink\": \"https://youtube.com/watch?v=example\",\n  \"status\": \"NOW_SELLING\",\n  \"description\": \"When the menace known as the Joker wreaks havoc on Gotham...\",\n  \"location\": \"Sydney\",\n  \"organizer\": \"Warner Bros\",\n  \"type\": \"MOVIE\",\n  \"cardImage\": \"/uploads/events/dark-knight-card.jpg\",\n  \"bannerImage\": \"/uploads/events/dark-knight-banner.jpg\",\n  \"releaseDate\": \"2026-04-01T00:00:00.000Z\",\n  \"duration\": \"152 min\",\n  \"eventCurrency\": \"AUD\"\n}"
                },
                "description": "Create a new cinema event."
              },
              "response": [],
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const data = pm.response.json().data;",
                      "if (data && data.id) {",
                      "  pm.collectionVariables.set('eventId', data.id);",
                      "  console.log('eventId set:', data.id);",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Update Event",
              "request": {
                "method": "PATCH",
                "url": { "raw": "{{baseUrl}}/admin/events/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["admin", "events", "{{eventId}}"] },
                "header": [
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" },
                  { "key": "Content-Type",  "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"status\": \"UPCOMING\",\n  \"description\": \"Updated description.\"\n}"
                },
                "description": "Partially update an existing event by ID."
              },
              "response": []
            },
            {
              "name": "Delete Event",
              "request": {
                "method": "DELETE",
                "url": { "raw": "{{baseUrl}}/admin/events/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["admin", "events", "{{eventId}}"] },
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "description": "Soft-delete an event by ID."
              },
              "response": []
            }
          ]
        },

