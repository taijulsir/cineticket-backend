        {
          "name": "Halls",
          "item": [
            {
              "name": "Create Hall",
              "request": {
                "method": "POST",
                "url": { "raw": "{{baseUrl}}/admin/halls", "host": ["{{baseUrl}}"], "path": ["admin", "halls"] },
                "header": [
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" },
