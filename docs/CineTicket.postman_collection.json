{
  "info": {
    "name": "CineTicket Backend API",
    "_postman_id": "cineticket-backend-v1",
    "description": "Complete API collection for the CineTicket NestJS backend.\n\nBase URL: {{baseUrl}}\n\nEnvironment variables required:\n- baseUrl\n- accessToken\n- refreshToken\n- eventId\n- showId\n- theaterId\n- hallId\n- orderId\n- promoCodeId",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:5011/api", "type": "string" },
    { "key": "accessToken",  "value": "",                          "type": "string" },
    { "key": "refreshToken", "value": "",                          "type": "string" },
    { "key": "eventId",      "value": "",                          "type": "string" },
    { "key": "showId",       "value": "",                          "type": "string" },
    { "key": "theaterId",    "value": "",                          "type": "string" },
    { "key": "hallId",       "value": "",                          "type": "string" },
    { "key": "orderId",      "value": "",                          "type": "string" },
    { "key": "promoCodeId",  "value": "",                          "type": "string" }
  ],
  "item": [

    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] },
            "description": "Returns API health status including database connectivity."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('success is true', () => pm.expect(pm.response.json().success).to.be.true);"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password@123\",\n  \"role\": \"Admin\"\n}"
            },
            "description": "Authenticate and receive access + refresh token pair.\nThrottled to 10 requests per 60 seconds."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
                  "const data = pm.response.json().data;",
                  "if (data && data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "  console.log('Tokens stored in collection variables.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "description": "Rotate refresh token. Returns new access + refresh token pair. Old refresh token is revoked."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json().data;",
                  "if (data && data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "description": "Revoke the provided refresh token."
          },
          "response": []
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/profile", "host": ["{{baseUrl}}"], "path": ["auth", "profile"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "description": "Returns the decoded JWT payload of the current user. Requires valid access token."
          },
          "response": []
        },
        {
          "name": "Admin Example (Admin only)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/admin-example", "host": ["{{baseUrl}}"], "path": ["auth", "admin-example"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "description": "Admin-only protected route example. Returns { ok: true }."
          },
          "response": []
        }
      ]
    },

    {
      "name": "Events",
      "item": [
        {
          "name": "List Events",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/events?status=NOW_SELLING&type=MOVIE&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["events"],
              "query": [
                { "key": "status", "value": "NOW_SELLING", "description": "EventStatus: NOW_SELLING | UPCOMING | VOTE_TO_BRING | PAST" },
                { "key": "type",   "value": "MOVIE",       "description": "EventType: MOVIE | OTHERS" },
                { "key": "page",   "value": "1" },
                { "key": "limit",  "value": "10" }
              ]
            },
            "description": "Public endpoint. Returns paginated list of events. Supports filtering by status, type, date, location."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json().data;",
                  "if (data && data.length > 0) {",
                  "  pm.collectionVariables.set('eventId', data[0].id);",
                  "  console.log('eventId set:', data[0].id);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "Shows",
      "item": [
        {
          "name": "List Shows",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/shows?eventId={{eventId}}&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["shows"],
              "query": [
                { "key": "eventId", "value": "{{eventId}}", "description": "Filter by event UUID" },
                { "key": "page",    "value": "1" },
                { "key": "limit",   "value": "10" }
              ]
            },
            "description": "Public endpoint. Returns list of shows, optionally filtered by eventId, city, date."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json().data;",
                  "if (data && data.length > 0) {",
                  "  pm.collectionVariables.set('showId', data[0].id);",
                  "  console.log('showId set:', data[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Show Seats",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/shows/{{showId}}/seats", "host": ["{{baseUrl}}"], "path": ["shows", "{{showId}}", "seats"] },
            "description": "Returns full seat list for a show with merged live status (AVAILABLE, RESERVED, BOOKED, BLOCKED)."
          },
          "response": []
        },
        {
          "name": "Get Show Seat Map",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/shows/{{showId}}/seat-map", "host": ["{{baseUrl}}"], "path": ["shows", "{{showId}}", "seat-map"] },
            "description": "Returns seat map grouped by rows. Useful for rendering an interactive seat picker UI."
          },
          "response": []
        }
      ]
    },

    {
      "name": "Seat Map",
      "item": [
        {
          "name": "Get Show Seat Layout",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/show-seats/layout/{{showId}}", "host": ["{{baseUrl}}"], "path": ["show-seats", "layout", "{{showId}}"] },
            "description": "Returns raw show seat layout for a given show ID."
          },
          "response": []
        }
      ]
    },

    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"mobileNumber\": \"+61400000000\",\n  \"eventId\": \"{{eventId}}\",\n  \"showId\": \"{{showId}}\",\n  \"seatIds\": [\"<showSeatId1>\", \"<showSeatId2>\"],\n  \"promoCodeId\": null,\n  \"total\": 45.00\n}"
            },
            "description": "Create a ticket order. Atomically books selected seats (transitions AVAILABLE → RESERVED/BOOKED). Rate limited to 5 requests per 60 seconds."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json().data;",
                  "if (data && data.id) {",
                  "  pm.collectionVariables.set('orderId', data.id);",
                  "  console.log('orderId set:', data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/orders/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["orders", "{{orderId}}"] },
            "description": "Get a single order with its line items by order UUID."
          },
          "response": []
        },
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/orders?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [
                { "key": "customerId", "value": "", "description": "Filter by customer UUID (optional)" },
                { "key": "page",       "value": "1" },
                { "key": "limit",      "value": "20" }
              ]
            },
            "description": "Paginated list of orders. Filter by customerId, page, and limit."
          },
          "response": []
        }
      ]
    },

    {
      "name": "Payments",
      "item": [
        {
          "name": "Payment Health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/payments/health", "host": ["{{baseUrl}}"], "path": ["payments", "health"] },
            "description": "Check payment subsystem health."
          },
          "response": []
        },
        {
          "name": "Mock — Start Payment",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/payments/mock/start", "host": ["{{baseUrl}}"], "path": ["payments", "mock", "start"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\"\n}"
            },
            "description": "Creates a mock payment session for a PENDING order. Returns a session token or redirect URL."
          },
          "response": []
        },
        {
          "name": "Mock — Confirm Payment",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/payments/mock/confirm", "host": ["{{baseUrl}}"], "path": ["payments", "mock", "confirm"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"transactionId\": \"txn_mock_abc123\"\n}"
            },
            "description": "Confirms payment for a PENDING order. Transitions order → CONFIRMED and seats → BOOKED."
          },
          "response": []
        },
        {
          "name": "Mock — Fail Payment",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/payments/mock/fail", "host": ["{{baseUrl}}"], "path": ["payments", "mock", "fail"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\"\n}"
            },
            "description": "Marks a PENDING order as EXPIRED and releases reserved seats back to AVAILABLE."
          },
          "response": []
        }
      ]
    },

