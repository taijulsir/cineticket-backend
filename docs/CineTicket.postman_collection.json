                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"theaterId\": \"{{theaterId}}\",\n  \"name\": \"Hall A\",\n  \"numberOfRows\": 10,\n  \"numberOfColumns\": 20\n}"
